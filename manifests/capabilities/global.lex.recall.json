{
  "manifestVersion": "ax/v0",
  "id": "global.lex.recall",
  "summary": "Recall frames from Lex (read-only).",
  "provider": "lex",
  "adapterType": "cli",
  "executionTarget": {
    "command": "lex",
    "args": ["recall", "--json"]
  },
  "argsSchema": {
    "type": "object",
    "properties": {
      "query": { "type": "string" },
      "list": { "type": "integer", "minimum": 1 },
      "exact": { "type": "boolean" },
      "fold-radius": { "type": "integer", "minimum": 0 },
      "auto-radius": { "type": "boolean" },
      "max-tokens": { "type": "integer", "minimum": 1 }
    }
  },
  "outputModes": ["json"],
  "sideEffects": "read",
  "scope": "global",
  "lifecycleState": "active",
  "defaults": {},
  "policies": [],
  "owner": "module:lex",
  "examples": [
    "ax run lex recall --list 5",
    "ax run lex recall --query 'recent work'"
  ]
}
