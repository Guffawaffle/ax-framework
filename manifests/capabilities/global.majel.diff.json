{
  "manifestVersion": "axf/v0",
  "id": "global.majel.diff",
  "summary": "Majel uncommitted changes summary (file count, insertions, deletions, file list).",
  "provider": "majel",
  "adapterType": "cli",
  "providerAdapter": "majel",
  "executionTarget": {
    "command": "/srv/majel/bin/ax",
    "args": ["diff"]
  },
  "argsSchema": {
    "type": "object",
    "properties": {
      "staged": { "type": "boolean" },
      "main": { "type": "boolean" }
    },
    "additionalProperties": false
  },
  "outputModes": ["json"],
  "sideEffects": "read",
  "scope": "global",
  "lifecycleState": "active",
  "defaults": {},
  "policies": [],
  "owner": "module:majel",
  "examples": [
    "axf run majel diff",
    "axf run majel diff --staged",
    "axf run majel diff --main"
  ]
}
