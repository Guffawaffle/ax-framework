{
  "manifestVersion": "ax/v0",
  "toolspace": "awa",
  "lifecycleState": "active",
  "moduleMounts": {
    "lex": {
      "source": "global.lex",
      "mode": "proxy",
      "capabilities": ["frame.recall", "frame.write", "receipt.show"],
      "defaults": { "namespace": "awa" },
      "policies": ["require_workspace_binding"]
    }
  }
}
